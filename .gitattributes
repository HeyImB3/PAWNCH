# Keep line endings consistent (LF) across machines, no matter which OS commits.
# The game is served as static files; LF avoids noisy CRLF diffs from Windows.

# Auto-detect text files and normalize to LF in the repo.
* text=auto eol=lf

# Explicit text types (defensive — keeps these LF even if detection is unsure).
*.js   text eol=lf
*.mjs  text eol=lf
*.json text eol=lf
*.html text eol=lf
*.css  text eol=lf
*.md   text eol=lf
*.py   text eol=lf
*.svg  text eol=lf

# Binary assets — never apply line-ending conversion.
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary
*.ico  binary
*.wav  binary
*.mp3  binary
*.ogg  binary
